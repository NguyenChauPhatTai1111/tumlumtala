PORT=25055
APP_ENV=local
APP_VERSION=local
LOG_LEVEL=DEBUG
LOG_OUTPUT=pretty
LOG_CALLER=false

# Kết nối shared MySQL container (tumlumtala-users-mysql)
DB_HOST=localhost
DB_PORT=23306
DB_USER=tumlum
DB_PASSWORD=tala
DB_NAME=tumlumtala_messenger

JWT_SECRET=change-me

CORS_ORIGIN=http://localhost:3000

# Local upload (default: tự tìm ../frontend/uploads khi chạy local)
LOCAL_UPLOAD_DIR=../frontend/uploads
LOCAL_UPLOAD_BASE_URL=/api/v1/messenger-uploads

# Notification service (tuỳ chọn, dùng cho push call tới offline user)
# NOTIFICATION_SERVICE_ADDR=notification-api:8888
# NOTIFICATION_CALL_CHANNEL=alert
# NOTIFICATION_CALL_TIMEOUT=1500ms

# Đường dẫn thư mục chứa GIF sticker (mặc định tự tìm ../../backend/seed-assets/stickers)
# STICKER_ASSETS_DIR=/path/to/backend/seed-assets/stickers
# Extension dùng khi seed URL local mà không có asset local để dò filename
# STICKER_FILE_EXTENSION=.png
