PORT=25055
APP_ENV=local
APP_VERSION=local
LOG_LEVEL=DEBUG
LOG_OUTPUT=pretty
LOG_CALLER=false

# Kết nối shared MySQL container (tumlumtala-users-mysql)
DB_HOST=localhost
DB_PORT=23306
DB_USER=tumlum
DB_PASSWORD=tala
DB_NAME=tumlumtala_messenger

JWT_SECRET=change-me

CORS_ORIGIN=http://localhost:3000

BUNNYCDN_API_KEY=
BUNNYCDN_STORAGE_ZONE=
BUNNYCDN_STORAGE_BASE_URL=https://storage.bunnycdn.com
BUNNYCDN_CDN_BASE_URL=

# Local upload fallback when BunnyCDN is not configured
LOCAL_UPLOAD_DIR=../frontend/uploads
LOCAL_UPLOAD_BASE_URL=/api/v1/messenger-uploads

# Đường dẫn thư mục chứa GIF sticker (mặc định tự tìm ../../backend/seed-assets/stickers)
# STICKER_ASSETS_DIR=/path/to/backend/seed-assets/stickers
# Extension dùng khi seed URL BunnyCDN mà không có asset local để dò filename
# STICKER_FILE_EXTENSION=.png
