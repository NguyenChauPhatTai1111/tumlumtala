APP_NAME=notification-service
APP_ENV=local
APP_PORT=8888

LOG_LEVEL=info
LOG_JSON=true

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=notification.exchange
RABBITMQ_QUEUE=notification.send
RABBITMQ_ROUTING_KEY=notification.send
RABBITMQ_RETRY_EXCHANGE=notification.retry.exchange
RABBITMQ_RETRY_QUEUE=notification.retry
RABBITMQ_RETRY_ROUTING_KEY=notification.retry
RABBITMQ_DLQ_EXCHANGE=notification.dlq.exchange
RABBITMQ_DLQ_QUEUE=notification.dlq
RABBITMQ_DLQ_ROUTING_KEY=notification.dlq
RABBITMQ_PREFETCH=16
NOTIFICATION_WORKERS=4
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=30000

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Brevo SMTP: host=smtp-relay.brevo.com, username=Brevo login, password=SMTP key.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@tumlumtala.local
SMTP_FROM_NAME=Tumlumtala

ZALO_ENDPOINT=
ZALO_TOKEN=
